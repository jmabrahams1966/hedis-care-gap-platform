# Copy to .env and fill in for production.
# Local dev works with the defaults (SQLite, dev_mode on) — no .env needed.

# Aurora/RDS Postgres async URL for production:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=sqlite+aiosqlite:///./hedis_care_gap.db

# Generate a strong secret in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=dev-insecure-change-me
JWT_TTL_HOURS=12
MAGIC_TTL_MINUTES=30

# MUST be false in production. When true, magic-link tokens are returned in the
# API response (for local testing) instead of being sent by SMS/email.
DEV_MODE=true

# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,https://app.example.com

DEFAULT_TENANT_SLUG=demo

# --- AWS (production) ---
AWS_REGION=us-east-1
SES_FROM_EMAIL=no-reply@example.com
SES_CONFIGURATION_SET=hedis-care-gap
SMS_ORIGINATION_NUMBER=+18445550100
# ARN of the AWS End User Messaging (Pinpoint SMS) configuration used to send outreach
SMS_CONFIGURATION_SET=hedis-care-gap-sms

# KMS key ARN used to encrypt PHI columns / attachments (see docs/SECURITY_HIPAA.md)
KMS_KEY_ARN=
